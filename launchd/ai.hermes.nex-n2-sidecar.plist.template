    <key>NEX_N2_DEEP_CONCURRENCY</key><string>1</string>
    <key>NEX_N2_REQUEST_TIMEOUT</key><string>900</string>
  </dict>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>WorkingDirectory</key><string>/Users/lee/programming/hermes-nex-n2-sidecar</string>
  <key>StandardOutPath</key><string>/Users/lee/.local/log/hermes-nex-n2-sidecar/stdout.log</string>
  <key>StandardErrorPath</key><string>/Users/lee/.local/log/hermes-nex-n2-sidecar/stderr.log</string>
</dict>
</plist>
